  </div>
  <div class="search-bar">
    <input class="search-input" placeholder="ابحث عن مستخدم أو موضوع..."/>
  </div>
  <div style="flex:1;display:flex;overflow:hidden">
    <!-- سايدبار الأفتار -->
    <div style="width:58px;flex-shrink:0;display:flex;flex-direction:column;align-items:center;padding:14px 0 14px;border-left:1px solid rgba(255,255,255,0.08);background:rgba(0,0,0,0.12);gap:8px;overflow:hidden">
      <!-- أفتار المستخدم -->
      <div style="width:40px;height:40px;border-radius:50%;background:var(--g2);border:2px solid rgba(255,255,255,0.35);display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:700;flex-shrink:0">س</div>
      <!-- زر السهم -->
      <div onclick="toggleBubbles()" id="arrowBtn" style="width:28px;height:28px;border-radius:50%;background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);display:flex;align-items:center;justify-content:center;cursor:pointer;transition:transform 0.3s;flex-shrink:0">
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.75)" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 12 15 18 9"/></svg>
      </div>
      <!-- دوائر الفلتر -->
      <div id="filterBubble1" class="fbub" onclick="filterPosts('متابعون',this)" title="متابعون" style="transition-delay:0.05s">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(100,220,255,0.9)" stroke-width="1.8" stroke-linecap="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        <span>متابعون</span>
      </div>
