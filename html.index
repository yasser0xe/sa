  </div>
</div>

<!-- ===== MESSAGES ===== -->
<div id="messages" class="screen">
  <div class="page-header">
    <div class="back-btn" onclick="go('home')"><svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg></div>
    <div class="page-title">المحادثات</div><div class="ph-spacer"></div>
  </div>
  <div class="scroll-body">
    <div class="convo-item" onclick="go('chat')">
      <div class="convo-av" style="background:#3a6b35">م</div>
      <div class="convo-info"><div class="convo-name">محمد العتيبي</div><div class="convo-prev">رأيك في تطورات الملف اليمني؟</div></div>
      <div style="display:flex;flex-direction:column;align-items:flex-end;gap:4px"><div class="convo-time">10:24</div><div class="convo-badge">2</div></div>
    </div>
    <div class="convo-item" onclick="go('chat')">
      <div class="convo-av" style="background:#2a5080">س</div>
      <div class="convo-info"><div class="convo-name">سارة القحطاني</div><div class="convo-prev">شكراً على التحليل</div></div>
      <div><div class="convo-time">أمس</div></div>
    </div>
  </div>
</div>

<!-- ===== CHAT ===== -->
<div id="chat" class="screen">
  <div class="page-header">
    <div class="back-btn" onclick="go('messages')"><svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg></div>
    <div class="page-title">محمد العتيبي</div><div class="ph-spacer"></div>
  </div>
  <div class="chat-body" id="chatArea">
    <div class="msg them"><div class="msg-bubble">مرحباً، رأيك في تطورات الملف اليمني؟</div><div class="msg-time">10:20</div></div>
    <div class="msg me"><div class="msg-bubble">أرى أن المفاوضات تسير ببطء لكن في الاتجاه الصحيح</div><div class="msg-time">10:22</div></div>
    <div class="msg them"><div class="msg-bubble">هل تعتقد أن الهدنة ستصمد هذه المرة؟</div><div class="msg-time">10:24</div></div>
  </div>
  <div class="chat-input-bar">
    <input class="chat-input" id="chatInput" placeholder="اكتب رسالة..."/>
    <button class="send-btn" onclick="sendMsg()">
      <svg viewBox="0 0 24 24" fill="none" stroke="var(--g1)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
    </button>
  </div>
</div>

<!-- ===== PROFILE ===== -->
<div id="profile" class="screen">
  <div class="page-header">
    <div class="back-btn" onclick="go('home')"><svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg></div>
    <div class="page-title">ملفي</div><div class="ph-spacer"></div>
  </div>
  <div style="flex:1;overflow-y:auto">
    <div class="profile-cover"><div class="profile-av">س</div></div>
    <div class="profile-info">
      <div class="profile-name">سعود</div>
      <div class="profile-handle">@saud · الرياض</div>
      <div class="profile-stats">
        <div><div class="stat-n">0</div><div class="stat-l">منشور</div></div>
        <div><div class="stat-n">0</div><div class="stat-l">متابِع</div></div>
        <div><div class="stat-n">0</div><div class="stat-l">متابَع</div></div>
        <div><div class="stat-n">0</div><div class="stat-l">نقطة</div></div>
      </div>
      <span class="profile-level">محلل مبتدئ</span>
    </div>
    <div class="page-tabs">
      <button class="page-tab active">المنشورات</button>
      <button class="page-tab">التوقعات</button>
      <button class="page-tab">المميزة</button>
    </div>
    <div style="padding:20px">
      <div class="empty-state">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        <p>لم تنشر أي منشور بعد</p>
      </div>
    </div>
  </div>
</div>

<!-- ===== SETTINGS ===== -->
<div id="settings" class="screen">
  <div class="page-header">
    <div class="back-btn" onclick="go('home')"><svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg></div>
    <div class="page-title">الإعدادات</div><div class="ph-spacer"></div>
  </div>
  <div class="scroll-body">
    <div class="card" style="display:flex;align-items:center;gap:12px;margin-bottom:20px">
      <div style="width:50px;height:50px;border-radius:50%;background:var(--g2);display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:700;border:2px solid rgba(255,255,255,0.3)">س</div>
      <div><div style="font-size:16px;font-weight:700;font-family:'Amiri',serif">سعود</div><div style="font-size:12px;color:var(--dim)">@saud · الرياض · انضم مارس ٢٠٢٦</div></div>
    </div>
    <div class="settings-section-title">الخصوصية</div>
    <div class="setting-item">
      <div class="setting-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></div>
      <div class="setting-text"><div class="setting-title">حساب خاص</div><div class="setting-sub">يرى منشوراتك المتابعون فقط</div></div>
      <div class="toggle" onclick="this.classList.toggle('on')"><div class="toggle-k"></div></div>
    </div>
    <div class="settings-section-title">الحساب</div>
    <div class="setting-item">
      <div class="setting-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg></div>
      <div class="setting-text"><div class="setting-title">تغيير كلمة المرور</div><div class="setting-sub">تحديث كلمة المرور الحالية</div></div>
      <svg viewBox="0 0 24 24" fill="none" stroke="var(--dim)" stroke-width="1.5" stroke-linecap="round" style="width:15px;height:15px;flex-shrink:0"><polyline points="15 18 9 12 15 6"/></svg>
    </div>
    <div class="setting-item" style="margin-top:14px">
      <div class="setting-icon"><svg viewBox="0 0 24 24" fill="none" stroke-width="1.5" stroke-linecap="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg></div>
      <div class="setting-text"><div class="setting-title">تسجيل الخروج</div></div>
    </div>
    <div class="setting-item" style="border-color:rgba(231,76,60,0.3)">
      <div class="setting-icon" style="background:rgba(231,76,60,0.1)"><svg viewBox="0 0 24 24" fill="none" stroke="#e74c3c" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg></div>
      <div class="setting-text"><div class="setting-title" style="color:#e74c3c">حذف الحساب</div><div class="setting-sub">إجراء لا يمكن التراجع عنه</div></div>
    </div>
  </div>
</div>

<!-- ===== ADD PREDICTION MODAL ===== -->
<div class="modal-overlay" id="addPred">
  <div class="modal-sheet">
    <div class="modal-header">
      <div class="modal-title">أضف توقعك</div>
      <div class="modal-close" onclick="closeModal('addPred')"><svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></div>
    </div>
    <label class="form-label">عنوان التوقع</label>
    <input class="form-input" placeholder="اكتب عنوان توقعك..."/>
    <label class="form-label">التحليل والأسباب</label>
    <textarea class="form-textarea" placeholder="اشرح أسباب توقعك وتحليلك..."></textarea>
    <label class="form-label">التصنيف</label>
    <div class="cat-btns">
      <button class="cat-btn" onclick="selCat(this)">داخلي</button>
      <button class="cat-btn" onclick="selCat(this)">خارجي</button>
      <button class="cat-btn" onclick="selCat(this)">اقتصاد</button>
      <button class="cat-btn" onclick="selCat(this)">أمن</button>
    </div>
    <label class="form-label">نسبة الاحتمال</label>
    <div class="slider-wrap">
      <div class="slider-val" id="sliderVal">50%</div>
      <input class="slider" type="range" min="0" max="100" value="50" oninput="document.getElementById('sliderVal').textContent=this.value+'%'"/>
    </div>
    <label class="form-label">تاريخ الانتهاء</label>
    <div class="date-row">
      <select class="date-sel"><option>اليوم</option></select>
      <select class="date-sel">
        <option>يناير</option><option>فبراير</option><option>مارس</option>
        <option>أبريل</option><option>مايو</option><option>يونيو</option>
        <option>يوليو</option><option>أغسطس</option><option>سبتمبر</option>
        <option>أكتوبر</option><option>نوفمبر</option><option>ديسمبر</option>
      </select>
      <select class="date-sel">
        <option>2025</option><option>2026</option><option>2027</option><option>2028</option>
      </select>
    </div>
    <button class="btn-save" onclick="savePred()">حفظ التوقع</button>
  </div>
</div>

<script>
function go(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}
function openModal(id){document.getElementById(id).classList.add('open')}
function closeModal(id){document.getElementById(id).classList.remove('open')}
function selCat(btn){
  document.querySelectorAll('.cat-btn').forEach(b=>b.classList.remove('sel'));
  btn.classList.add('sel');
}
function savePred(){
  if(confirm('هل أنت متأكد من حفظ التوقع؟')){
    closeModal('addPred');
    alert('تم حفظ توقعك بنجاح ✓');
  }
}
function sendMsg(){
  const input=document.getElementById('chatInput');
  const text=input.value.trim();
  if(!text)return;
  const area=document.getElementById('chatArea');
  const now=new Date();
  const msg=document.createElement('div');
  msg.className='msg me';
  msg.innerHTML=`<div class="msg-bubble">${text}</div><div class="msg-time">${now.getHours()}:${String(now.getMinutes()).padStart(2,'0')}</div>`;
  area.appendChild(msg);area.scrollTop=area.scrollHeight;input.value='';
}
function sendAI(){
  const input=document.getElementById('aiInput');
  const text=input.value.trim();
  if(!text)return;
  const area=document.getElementById('aiChat');
  const userMsg=document.createElement('div');
  userMsg.className='msg me';
  userMsg.innerHTML=`<div class="msg-bubble">${text}</div><div class="msg-time">الآن</div>`;
  area.appendChild(userMsg);input.value='';
  setTimeout(()=>{
    const bot=document.createElement('div');
    bot.className='msg them';
    bot.innerHTML=`<div class="msg-bubble"><div class="ai-tag">المحلل الذكي</div>سؤال وجيه — يتطلب قراءة معمقة للمشهد السياسي الراهن ومعطياته الإقليمية.</div><div class="msg-time">الآن</div>`;
    area.appendChild(bot);area.scrollTop=area.scrollHeight;
  },700);
  area.scrollTop=area.scrollHeight;
}
let bubblesOpen=false;
function toggleBubbles(){
  bubblesOpen=!bubblesOpen;
  [1,2,3,4].forEach(i=>{
    const b=document.getElementById('filterBubble'+i);
    if(bubblesOpen) b.classList.add('show');
    else b.classList.remove('show');
  });
  const arrow=document.getElementById('arrowBtn');
  arrow.style.transform=bubblesOpen?'rotate(180deg)':'rotate(0deg)';
}
function filterPosts(f,el){
  document.querySelectorAll('.fbub').forEach(b=>b.classList.remove('active-filter'));
  if(el) el.classList.add('active-filter');
}
function togglePostsMenu(){}
function toggleCity(){
  const d=document.getElementById('cityDropdown');
  d.style.display=d.style.display==='none'?'block':'none';
}
function selectCity(city){
  document.getElementById('cityText').textContent=city;
  document.getElementById('cityBtn').classList.add('selected');
  document.getElementById('cityDropdown').style.display='none';
}
document.getElementById('chatInput').addEventListener('keypress',e=>{if(e.key==='Enter')sendMsg()});
document.getElementById('aiInput').addEventListener('keypress',e=>{if(e.key==='Enter')sendAI()});

// تحويل الشعارات الكبيرة إلى 9+
function formatBadge(n){ return n > 9 ? '9+' : n; }
document.querySelectorAll('.b-badge').forEach(b=>{
  const num = parseInt(b.textContent);
  if(!isNaN(num)) b.textContent = formatBadge(num);
});
// التاريخ
const d=new Date();
const el=document.getElementById('homeDate');
if(el) el.textContent=d.toLocaleDateString('ar-SA',{weekday:'long',year:'numeric',month:'long',day:'numeric'});

const daysel=document.querySelectorAll('.date-sel')[0];
for(let i=1;i<=31;i++){const o=document.createElement('option');o.value=i;o.textContent=i;daysel.appendChild(o);}
</script>
</body>
</html>
