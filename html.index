        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(255,120,120,0.9)" stroke-width="1.8" stroke-linecap="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        <span>لايكاتي</span>
      </div>
      <div id="filterBubble3" class="fbub" onclick="filterPosts('ريبوستاتي',this)" title="ريبوستاتي" style="transition-delay:0.15s">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(100,255,160,0.9)" stroke-width="1.8" stroke-linecap="round"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
        <span>ريبوستاتي</span>
      </div>
      <div id="filterBubble4" class="fbub" onclick="filterPosts('مفضلتي',this)" title="مفضلتي" style="transition-delay:0.2s">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(255,210,60,0.9)" stroke-width="1.8" stroke-linecap="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        <span>مفضلتي</span>
      </div>
