<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>المشهد السعودي</title>
<link href="https://fonts.googleapis.com/css2?family=Amiri:wght@400;700&family=Tajawal:wght@300;400;500;700;900&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
:root{
  --g1:#1a3c2e;--g2:#2d6a4f;--g3:#52b788;
  --white:#ffffff;--text:#1e2d1c;
  --card:rgba(255,255,255,0.13);--card-border:rgba(255,255,255,0.22);
  --gold:#f0c040;--red:#e74c3c;--dim:rgba(255,255,255,0.55);
  --shadow:0 4px 24px rgba(0,0,0,0.18);
}
body{
  font-family:'Tajawal',sans-serif;
  background:linear-gradient(145deg,var(--g1) 0%,var(--g2) 55%,var(--g3) 100%);
  min-height:100vh;color:var(--white);overflow:hidden;
  display:flex;flex-direction:column;
}
/* SCREENS */
.screen{display:none;flex-direction:column;height:100vh;overflow:hidden}
.screen.active{display:flex}

/* ========== LOGIN ========== */
#login{align-items:center;justify-content:center;padding:20px}
.auth-card{
  background:rgba(255,255,255,0.1);
  backdrop-filter:blur(20px);
  border:1px solid rgba(255,255,255,0.2);
  border-radius:24px;padding:36px 28px;
  width:100%;max-width:380px;
  box-shadow:0 8px 40px rgba(0,0,0,0.25);
}
.auth-welcome{
  font-family:'Amiri',serif;font-size:28px;font-weight:700;
  text-align:center;margin-bottom:6px;color:var(--white);
}
.auth-sub{font-size:12px;color:var(--dim);text-align:center;margin-bottom:28px;letter-spacing:1px}
.field-group{margin-bottom:18px}
.field-label{font-size:12px;font-weight:500;color:rgba(255,255,255,0.8);margin-bottom:6px;display:block}
.field-input{
  width:100%;padding:12px 14px;
  background:rgba(255,255,255,0.08);
  border:1px solid rgba(255,255,255,0.2);
  border-radius:12px;color:var(--white);
  font-family:'Tajawal',sans-serif;font-size:14px;
  outline:none;transition:border-color 0.2s;
}
.field-input::placeholder{color:rgba(255,255,255,0.35)}
.field-input:focus{border-color:rgba(255,255,255,0.5);background:rgba(255,255,255,0.12)}
.btn-main{
  width:100%;padding:13px;background:var(--white);
  color:var(--g1);border:none;border-radius:12px;
  font-family:'Tajawal',sans-serif;font-size:15px;font-weight:700;
  cursor:pointer;transition:all 0.2s;margin-top:8px;
}
.btn-main:hover{background:rgba(255,255,255,0.9);transform:translateY(-1px)}
.btn-main:active{transform:translateY(0)}
.auth-link{text-align:center;margin-top:18px;font-size:13px;color:var(--dim)}
.auth-link a{color:var(--white);font-weight:700;cursor:pointer;text-decoration:none}

/* ========== REGISTER ========== */
#register{align-items:center;justify-content:center;padding:20px;overflow-y:auto}
.back-top{
  position:absolute;top:20px;right:20px;
  width:36px;height:36px;border-radius:50%;
  background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);
  display:flex;align-items:center;justify-content:center;cursor:pointer;
}
.back-top svg{width:16px;height:16px;stroke:var(--white)}

/* ========== VERIFY ========== */
#verify{align-items:center;justify-content:center;padding:20px}
.code-boxes{display:flex;gap:10px;justify-content:center;margin:20px 0;direction:ltr}
.code-box{
  width:46px;height:54px;border-radius:12px;
  background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.2);
  color:var(--white);font-size:22px;font-weight:700;text-align:center;
  font-family:'Tajawal',sans-serif;outline:none;
}
.code-box:focus{border-color:var(--white);background:rgba(255,255,255,0.15)}
.resend-link{color:var(--dim);font-size:13px;text-align:center;cursor:pointer;margin-top:12px}
.resend-link span{color:var(--white);font-weight:700}

/* ========== HOME ========== */
#home{position:relative}
.home-header{
  padding:16px 20px;display:flex;align-items:center;justify-content:space-between;
  background:rgba(0,0,0,0.15);backdrop-filter:blur(12px);
  border-bottom:1px solid rgba(255,255,255,0.08);flex-shrink:0;
}
.logo-text{font-family:'Amiri',serif;font-size:20px;font-weight:700;color:var(--white)}
.user-btn{
  width:38px;height:38px;border-radius:50%;
  background:rgba(255,255,255,0.15);border:2px solid rgba(255,255,255,0.3);
  display:flex;align-items:center;justify-content:center;
  font-size:15px;font-weight:700;cursor:pointer;
}
.home-quote{
  text-align:center;padding:12px 24px;
  font-size:12px;color:rgba(255,255,255,0.7);
  font-style:italic;letter-spacing:0.5px;
  border-bottom:1px solid rgba(255,255,255,0.08);
  flex-shrink:0;
}
.bubbles-wrap{
  flex:1;display:flex;align-items:center;justify-content:center;
  padding:10px 0 0;
}
.bubbles-grid{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:20px;padding:8px 22px;max-width:360px;width:100%;
}
.bw{display:flex;flex-direction:column;align-items:center;gap:8px}
.bubble{
  width:80px;height:80px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;position:relative;
  background:var(--card);border:1px solid var(--card-border);
  box-shadow:var(--shadow);transition:transform 0.2s;
}
.bubble.lg{width:90px;height:90px}
.bubble:hover{transform:scale(1.1) translateY(-3px)}
.bubble:active{transform:scale(0.95)}
.bubble svg{width:28px;height:28px;pointer-events:none}
.bubble.lg svg{width:32px;height:32px}
.b-badge{
  position:absolute;top:3px;left:3px;
  width:18px;height:18px;border-radius:50%;
  background:var(--red);border:2px solid var(--g1);
  display:flex;align-items:center;justify-content:center;
  font-size:8px;font-weight:700;z-index:2;
}
.b-name{font-size:10px;color:var(--dim);text-align:center}

/* Float animations */
@keyframes f1{0%,100%{transform:translateY(0)}50%{transform:translateY(-5px)}}
@keyframes f2{0%,100%{transform:translateY(0)}50%{transform:translateY(5px)}}
@keyframes f3{0%,100%{transform:translateY(0)translateX(0)}40%{transform:translateY(-4px)translateX(2px)}}
@keyframes f4{0%,100%{transform:translateY(0)}50%{transform:translateY(-6px)}}
@keyframes f5{0%,100%{transform:translateY(0)translateX(0)}60%{transform:translateY(3px)translateX(-2px)}}
.fa{animation:f1 5s ease-in-out infinite}
.fb{animation:f2 6s ease-in-out infinite 0.5s}
.fc{animation:f3 7s ease-in-out infinite 1s}
.fd{animation:f4 5.5s ease-in-out infinite 0.3s}
.fe{animation:f1 4.5s ease-in-out infinite 0.8s}
.ff{animation:f5 8s ease-in-out infinite 1.2s}
.fg{animation:f2 5s ease-in-out infinite 0.6s}
.fh{animation:f3 6.5s ease-in-out infinite 1.8s}
.fi{animation:f4 7s ease-in-out infinite 2s}
.bubble:hover{animation:none!important}

.home-bottom{
  padding:10px 20px;background:rgba(0,0,0,0.2);
  border-top:1px solid rgba(255,255,255,0.08);
  display:flex;align-items:center;justify-content:center;
  gap:8px;font-size:11px;color:var(--dim);flex-shrink:0;
}
.live-dot{
  width:7px;height:7px;border-radius:50%;background:var(--g3);
  animation:pulse 2s infinite;
}
@keyframes pulse{0%,100%{box-shadow:0 0 0 0 rgba(82,183,136,0.5)}50%{box-shadow:0 0 0 5px rgba(82,183,136,0)}}

/* ========== INNER PAGES ========== */
.page-header{
  padding:14px 18px;display:flex;align-items:center;justify-content:space-between;
  background:rgba(0,0,0,0.15);backdrop-filter:blur(12px);
  border-bottom:1px solid rgba(255,255,255,0.08);flex-shrink:0;
}
.page-title{font-family:'Amiri',serif;font-size:18px;font-weight:700}
.back-btn{
  width:34px;height:34px;border-radius:50%;
  background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);
  display:flex;align-items:center;justify-content:center;cursor:pointer;
  transition:background 0.2s;
}
.back-btn:hover{background:rgba(255,255,255,0.2)}
.back-btn svg{width:16px;height:16px;stroke:var(--white)}
.ph-spacer{width:34px}

/* SCROLL */
.scroll-body{flex:1;overflow-y:auto;padding:14px}
.scroll-body::-webkit-scrollbar{width:3px}
.scroll-body::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.2);border-radius:2px}

/* TABS */
.tabs-bar{
  display:flex;overflow-x:auto;gap:6px;padding:10px 14px;
  background:rgba(0,0,0,0.1);border-bottom:1px solid rgba(255,255,255,0.08);
  flex-shrink:0;scrollbar-width:none;
}
.tabs-bar::-webkit-scrollbar{display:none}
.tab-btn{
  padding:6px 14px;border-radius:20px;font-size:12px;font-weight:500;
  white-space:nowrap;cursor:pointer;border:1px solid rgba(255,255,255,0.2);
  background:transparent;color:var(--dim);font-family:'Tajawal',sans-serif;
  transition:all 0.2s;
}
.tab-btn.active{background:var(--white);color:var(--g1);border-color:var(--white)}

/* CARD */
.card{
  background:var(--card);border:1px solid var(--card-border);
  border-radius:16px;padding:14px;margin-bottom:10px;
  backdrop-filter:blur(8px);
}
.card-user{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.avatar{
  width:36px;height:36px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:14px;font-weight:700;flex-shrink:0;color:var(--white);
}
.u-name{font-size:13px;font-weight:700}
.u-handle{font-size:11px;color:var(--dim)}
.card-title{font-size:14px;font-weight:700;margin-bottom:6px;line-height:1.5}
.card-body{font-size:13px;line-height:1.7;color:rgba(255,255,255,0.85)}
.tag{
  display:inline-block;padding:2px 10px;border-radius:20px;
  font-size:10px;font-weight:700;margin-left:6px;
  background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);
}
.card-meta{
  display:flex;align-items:center;gap:10px;
  margin-top:10px;padding-top:10px;
  border-top:1px solid rgba(255,255,255,0.08);
  font-size:11px;color:var(--dim);
}
.action-btn{
  display:flex;align-items:center;gap:4px;
  background:none;border:none;color:var(--dim);
  font-family:'Tajawal',sans-serif;font-size:12px;cursor:pointer;
  transition:color 0.2s;padding:0;
}
.action-btn:hover{color:var(--white)}
.action-btn svg{width:13px;height:13px}

/* PROBABILITY BAR */
.prob-row{display:flex;align-items:center;gap:8px;margin:8px 0}
.prob-label{font-size:11px;color:var(--dim);white-space:nowrap}
.prob-track{flex:1;height:5px;background:rgba(255,255,255,0.1);border-radius:3px;overflow:hidden}
.prob-fill{height:100%;border-radius:3px;background:linear-gradient(90deg,var(--g3),var(--gold))}
.prob-pct{font-size:12px;font-weight:700;color:var(--gold)}

/* STATUS BADGE */
.status{display:inline-block;padding:2px 10px;border-radius:20px;font-size:10px;font-weight:700}
.status-pending{background:rgba(240,192,64,0.15);color:var(--gold);border:1px solid rgba(240,192,64,0.3)}
.status-yes{background:rgba(46,160,67,0.15);color:#52e07c;border:1px solid rgba(46,160,67,0.3)}
.status-no{background:rgba(231,76,60,0.15);color:#ff7c6e;border:1px solid rgba(231,76,60,0.3)}

/* ANALYSTS */
.analyst-row{
  display:flex;align-items:center;gap:12px;
  background:var(--card);border:1px solid var(--card-border);
  border-radius:14px;padding:12px 14px;margin-bottom:8px;
  cursor:pointer;
}
.rank{font-size:20px;font-weight:900;color:var(--gold);width:26px;text-align:center}
.analyst-info{flex:1}
.analyst-name{font-size:14px;font-weight:700}
.analyst-city{font-size:11px;color:var(--dim)}
.level-badge{
  display:inline-block;padding:2px 8px;border-radius:5px;
  font-size:9px;font-weight:700;margin-top:3px;
  background:rgba(240,192,64,0.15);color:var(--gold);
  border:1px solid rgba(240,192,64,0.25);
}
.score-circle{
  width:44px;height:44px;border-radius:50%;
  background:rgba(255,255,255,0.08);border:2px solid rgba(255,255,255,0.2);
  display:flex;flex-direction:column;align-items:center;justify-content:center;
}
.score-n{font-size:15px;font-weight:900;color:var(--gold);line-height:1}
.score-l{font-size:8px;color:var(--dim)}

/* CHAT */
.chat-body{flex:1;overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:8px}
.msg{max-width:78%}
.msg.me{align-self:flex-end}
.msg.them{align-self:flex-start}
.msg-bubble{padding:10px 14px;border-radius:16px;font-size:13px;line-height:1.6}
.msg.me .msg-bubble{background:rgba(255,255,255,0.15);border:1px solid rgba(255,255,255,0.2);border-bottom-left-radius:4px}
.msg.them .msg-bubble{background:rgba(0,0,0,0.2);border:1px solid rgba(255,255,255,0.1);border-bottom-right-radius:4px}
.msg-time{font-size:10px;color:var(--dim);margin-top:3px}
.msg.me .msg-time{text-align:left}
.chat-input-bar{
  padding:10px 14px;background:rgba(0,0,0,0.2);
  border-top:1px solid rgba(255,255,255,0.08);
  display:flex;gap:8px;align-items:center;flex-shrink:0;
}
.chat-input{
  flex:1;background:rgba(255,255,255,0.08);
  border:1px solid rgba(255,255,255,0.15);border-radius:22px;
  padding:10px 14px;color:var(--white);
  font-family:'Tajawal',sans-serif;font-size:13px;outline:none;
}
.chat-input::placeholder{color:rgba(255,255,255,0.3)}
.chat-input:focus{border-color:rgba(255,255,255,0.3)}
.send-btn{
  width:38px;height:38px;border-radius:50%;
  background:var(--white);border:none;cursor:pointer;
  display:flex;align-items:center;justify-content:center;
  transition:transform 0.2s;flex-shrink:0;
}
.send-btn:hover{transform:scale(1.08)}
.send-btn svg{width:15px;height:15px}

/* AI TAG */
.ai-tag{font-size:10px;color:var(--g3);font-weight:700;margin-bottom:5px}

/* PROFILE */
.profile-cover{
  height:90px;flex-shrink:0;position:relative;
  background:linear-gradient(135deg,var(--g1),var(--g2));
  border-bottom:1px solid rgba(255,255,255,0.1);
}
.profile-av{
  width:70px;height:70px;border-radius:50%;
  background:var(--g2);border:3px solid var(--white);
  display:flex;align-items:center;justify-content:center;
  font-size:26px;font-weight:700;
  position:absolute;bottom:-35px;right:18px;
  box-shadow:var(--shadow);
}
.profile-info{
  padding:40px 18px 14px;
  background:rgba(0,0,0,0.1);
  border-bottom:1px solid rgba(255,255,255,0.08);
  flex-shrink:0;
}
.profile-name{font-family:'Amiri',serif;font-size:20px;font-weight:700}
.profile-handle{font-size:12px;color:var(--dim);margin-bottom:10px}
.profile-stats{display:flex;gap:20px;margin-bottom:10px}
.stat-n{font-size:18px;font-weight:700;color:var(--white)}
.stat-l{font-size:10px;color:var(--dim)}
.profile-level{
  display:inline-block;padding:3px 12px;border-radius:20px;font-size:11px;font-weight:700;
  background:rgba(240,192,64,0.15);color:var(--gold);border:1px solid rgba(240,192,64,0.3);
}
.page-tabs{
  display:flex;background:rgba(0,0,0,0.1);
  border-bottom:1px solid rgba(255,255,255,0.08);flex-shrink:0;
}
.page-tab{
  flex:1;padding:11px;text-align:center;font-size:12px;
  color:var(--dim);cursor:pointer;transition:all 0.2s;
  font-family:'Tajawal',sans-serif;border:none;background:none;
}
.page-tab.active{color:var(--white);border-bottom:2px solid var(--white);font-weight:700}

/* SETTINGS */
.settings-section-title{
  font-size:10px;color:var(--dim);letter-spacing:2px;
  margin:16px 0 8px;padding:0 2px;
}
.setting-item{
  display:flex;align-items:center;gap:12px;
  background:var(--card);border:1px solid var(--card-border);
  border-radius:12px;padding:12px 14px;margin-bottom:7px;
  cursor:pointer;transition:background 0.2s;
}
.setting-item:hover{background:rgba(255,255,255,0.18)}
.setting-icon{
  width:34px;height:34px;border-radius:10px;
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
  background:rgba(255,255,255,0.08);
}
.setting-icon svg{width:17px;height:17px;stroke:var(--white)}
.setting-text{flex:1}
.setting-title{font-size:13px;font-weight:500}
.setting-sub{font-size:10px;color:var(--dim);margin-top:2px}
.toggle{
  width:42px;height:23px;border-radius:12px;
  background:rgba(255,255,255,0.15);border:1px solid rgba(255,255,255,0.2);
  position:relative;cursor:pointer;transition:background 0.3s;flex-shrink:0;
}
.toggle.on{background:var(--g3)}
.toggle-k{
  width:17px;height:17px;border-radius:50%;background:var(--white);
  position:absolute;top:2px;right:2px;transition:transform 0.3s;
  box-shadow:0 1px 4px rgba(0,0,0,0.3);
}
.toggle.on .toggle-k{transform:translateX(-19px)}

/* ARCHIVE */
.archive-card{
  background:var(--card);border:1px solid var(--card-border);
  border-radius:14px;padding:13px;margin-bottom:9px;
}
.arc-result{
  display:inline-block;padding:2px 9px;border-radius:5px;
  font-size:10px;font-weight:700;
}
.arc-yes{background:rgba(46,160,67,0.15);color:#52e07c;border:1px solid rgba(46,160,67,0.25)}
.arc-no{background:rgba(231,76,60,0.15);color:#ff7c6e;border:1px solid rgba(231,76,60,0.25)}
.arc-wait{background:rgba(240,192,64,0.15);color:var(--gold);border:1px solid rgba(240,192,64,0.25)}

/* MESSAGES LIST */
.convo-item{
  display:flex;align-items:center;gap:12px;
  background:var(--card);border:1px solid var(--card-border);
  border-radius:14px;padding:12px 14px;margin-bottom:8px;cursor:pointer;
  transition:background 0.2s;
}
.convo-item:hover{background:rgba(255,255,255,0.18)}
.convo-av{
  width:44px;height:44px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:16px;font-weight:700;flex-shrink:0;
}
.convo-info{flex:1}
.convo-name{font-size:14px;font-weight:700}
.convo-prev{font-size:12px;color:var(--dim);margin-top:2px}
.convo-time{font-size:10px;color:var(--dim)}
.convo-badge{
  width:18px;height:18px;border-radius:50%;background:var(--red);
  display:flex;align-items:center;justify-content:center;
  font-size:9px;font-weight:700;
}

/* FAB */
.fab{
  position:fixed;bottom:70px;left:18px;
  width:52px;height:52px;border-radius:50%;
  background:var(--white);color:var(--g1);
  border:none;font-size:26px;cursor:pointer;
  box-shadow:var(--shadow);display:flex;align-items:center;justify-content:center;
  transition:transform 0.2s;z-index:50;
}
.fab:hover{transform:scale(1.1)}

/* MODAL */
.modal-overlay{
  position:fixed;inset:0;background:rgba(0,0,0,0.6);
  backdrop-filter:blur(4px);z-index:100;
  display:none;align-items:flex-end;justify-content:center;
}
.modal-overlay.open{display:flex}
.modal-sheet{
  background:linear-gradient(180deg,var(--g1),#0d2618);
  border-radius:24px 24px 0 0;width:100%;max-width:500px;
  padding:20px;max-height:92vh;overflow-y:auto;
  border:1px solid rgba(255,255,255,0.1);border-bottom:none;
}
.modal-sheet::-webkit-scrollbar{width:3px}
.modal-sheet::-webkit-scrollbar-thumb{background:rgba(255,255,255,0.2)}
.modal-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px}
.modal-title{font-family:'Amiri',serif;font-size:20px;font-weight:700}
.modal-close{
  width:32px;height:32px;border-radius:50%;background:rgba(255,255,255,0.1);
  border:1px solid rgba(255,255,255,0.2);cursor:pointer;
  display:flex;align-items:center;justify-content:center;
}
.modal-close svg{width:14px;height:14px;stroke:var(--white)}
.form-label{font-size:12px;color:rgba(255,255,255,0.7);margin-bottom:6px;display:block;font-weight:500}
.form-input{
  width:100%;padding:11px 14px;margin-bottom:14px;
  background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.15);
  border-radius:12px;color:var(--white);
  font-family:'Tajawal',sans-serif;font-size:13px;outline:none;
}
.form-input:focus{border-color:rgba(255,255,255,0.35)}
.form-textarea{
  width:100%;padding:11px 14px;margin-bottom:14px;
  background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.15);
  border-radius:12px;color:var(--white);
  font-family:'Tajawal',sans-serif;font-size:13px;outline:none;
  resize:none;height:100px;overflow-y:auto;
  word-wrap:break-word;white-space:pre-wrap;
}
.form-textarea::placeholder{color:rgba(255,255,255,0.3)}
.form-input::placeholder{color:rgba(255,255,255,0.3)}
.cat-btns{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px}
.cat-btn{
  padding:6px 14px;border-radius:20px;font-size:12px;font-weight:500;
  border:1px solid rgba(255,255,255,0.2);background:transparent;
  color:var(--dim);cursor:pointer;font-family:'Tajawal',sans-serif;
  transition:all 0.2s;
}
.cat-btn.sel{background:var(--white);color:var(--g1);border-color:var(--white)}
.slider-wrap{margin-bottom:14px}
.slider-val{font-size:22px;font-weight:900;color:var(--gold);text-align:center;margin-bottom:8px}
.slider{width:100%;-webkit-appearance:none;height:5px;border-radius:3px;background:rgba(255,255,255,0.15);outline:none}
.slider::-webkit-slider-thumb{-webkit-appearance:none;width:20px;height:20px;border-radius:50%;background:var(--white);cursor:pointer;box-shadow:0 2px 8px rgba(0,0,0,0.3)}
.date-row{display:flex;gap:8px;margin-bottom:14px}
.date-sel{
  flex:1;padding:10px 8px;
  background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.15);
  border-radius:12px;color:var(--white);
  font-family:'Tajawal',sans-serif;font-size:12px;outline:none;
}
.date-sel option{background:var(--g1);color:var(--white)}
.btn-save{
  width:100%;padding:13px;background:var(--white);
  color:var(--g1);border:none;border-radius:12px;
  font-family:'Tajawal',sans-serif;font-size:15px;font-weight:700;
  cursor:pointer;margin-top:6px;transition:all 0.2s;
}
.btn-save:hover{background:rgba(255,255,255,0.9)}

/* EVENTS TAG */
.event-tag{
  display:inline-block;padding:2px 10px;border-radius:20px;
  font-size:10px;margin-bottom:7px;
  background:rgba(240,192,64,0.12);color:var(--gold);
  border:1px solid rgba(240,192,64,0.25);
}
.event-time{font-size:11px;color:var(--dim);margin-top:6px}

/* EMPTY */
.empty-state{text-align:center;padding:50px 20px;color:var(--dim)}
.empty-state svg{width:40px;height:40px;margin:0 auto 12px;display:block;opacity:0.4}
.empty-state p{font-size:13px}

/* CITY SELECT */
.city-btn{
  width:100%;padding:11px 14px;margin-bottom:14px;
  background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.15);
  border-radius:12px;color:rgba(255,255,255,0.5);
  font-family:'Tajawal',sans-serif;font-size:13px;
  text-align:right;cursor:pointer;display:flex;align-items:center;justify-content:space-between;
}
.city-btn.selected{color:var(--white)}
.city-dropdown{
  position:absolute;left:0;right:0;top:100%;
  background:var(--g1);border:1px solid rgba(255,255,255,0.15);
  border-radius:12px;max-height:200px;overflow-y:auto;z-index:200;
  box-shadow:var(--shadow);
}
.city-option{
  padding:11px 14px;font-size:13px;cursor:pointer;
  transition:background 0.15s;border-bottom:1px solid rgba(255,255,255,0.05);
}
.city-option:hover{background:rgba(255,255,255,0.1)}
.city-wrap{position:relative}

/* FILTER BUBBLES SIDEBAR */
.fbub{
  width:40px;height:40px;border-radius:50%;
  background:rgba(255,255,255,0.1);border:1px solid rgba(255,255,255,0.2);
  display:flex;align-items:center;justify-content:center;
  cursor:pointer;flex-shrink:0;position:relative;
  transform:scale(0) translateY(-10px);opacity:0;
  transition:transform 0.3s ease, opacity 0.3s ease, background 0.2s;
  pointer-events:none;
}
.fbub.show{transform:scale(1) translateY(0);opacity:1;pointer-events:all}
.fbub:hover{background:rgba(255,255,255,0.2);transform:scale(1.1)!important}
.fbub.active-filter{background:rgba(255,255,255,0.25);border-color:rgba(255,255,255,0.5)}
.fbub span{
  position:absolute;right:46px;
  background:rgba(0,0,0,0.7);color:#fff;
  font-size:10px;padding:3px 8px;border-radius:6px;
  white-space:nowrap;opacity:0;pointer-events:none;
  transition:opacity 0.2s;
}
.fbub:hover span{opacity:1}

.search-bar{
  padding:10px 14px;
  border-bottom:1px solid rgba(255,255,255,0.08);
  flex-shrink:0;
}
.search-input{
  width:100%;padding:9px 14px;
  background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);
  border-radius:22px;color:var(--white);
  font-family:'Tajawal',sans-serif;font-size:13px;outline:none;
}
.search-input::placeholder{color:rgba(255,255,255,0.3)}
</style>
</head>
<body>

<!-- ===== LOGIN ===== -->
<div id="login" class="screen active">
  <div class="auth-card" style="margin:auto">
    <div class="auth-welcome">حياك الله</div>
    <div class="auth-sub">المشهد السعودي</div>
    <div class="field-group">
      <label class="field-label">البريد الإلكتروني أو اسم المستخدم</label>
      <input class="field-input" type="text" placeholder="أدخل بريدك أو اسم المستخدم"/>
    </div>
    <div class="field-group">
      <label class="field-label">كلمة المرور</label>
      <input class="field-input" type="password" placeholder="أدخل كلمة المرور"/>
    </div>
    <button class="btn-main" onclick="go('home')">تسجيل الدخول</button>
    <div class="auth-link">ليس لديك حساب؟ <a onclick="go('register')">إنشاء حساب جديد</a></div>
  </div>
</div>

<!-- ===== REGISTER ===== -->
<div id="register" class="screen" style="position:relative;overflow-y:auto">
  <div class="back-top" onclick="go('login')">
    <svg viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round"><polyline points="15 18 9 12 15 6"/></svg>
  </div>
  <div class="auth-card" style="margin:auto;margin-top:60px;margin-bottom:20px">
    <div class="auth-welcome" style="font-size:22px">حضورك يشرفنا</div>
    <div class="auth-sub">أنشئ حسابك في المشهد السعودي</div>
    <div class="field-group">
      <label class="field-label">البريد الإلكتروني</label>
      <input class="field-input" type="email" placeholder="example@email.com"/>
    </div>
    <div class="field-group">
      <label class="field-label">الاسم</label>
      <input class="field-input" type="text" placeholder="اسمك الكامل"/>
    </div>
    <div class="field-group">
      <label class="field-label">اسم المستخدم</label>
      <input class="field-input" type="text" placeholder="username_example"/>
    </div>
    <div class="field-group">
      <label class="field-label">المدينة</label>
      <div class="city-wrap">
        <div class="city-btn" id="cityBtn" onclick="toggleCity()">
          <span id="cityText">اختر مدينتك</span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
        </div>
        <div class="city-dropdown" id="cityDropdown" style="display:none">
          <div class="city-option" onclick="selectCity('الرياض')">الرياض</div>
          <div class="city-option" onclick="selectCity('جدة')">جدة</div>
          <div class="city-option" onclick="selectCity('مكة المكرمة')">مكة المكرمة</div>
          <div class="city-option" onclick="selectCity('المدينة المنورة')">المدينة المنورة</div>
          <div class="city-option" onclick="selectCity('الدمام')">الدمام</div>
          <div class="city-option" onclick="selectCity('الخبر')">الخبر</div>
          <div class="city-option" onclick="selectCity('الظهران')">الظهران</div>
          <div class="city-option" onclick="selectCity('تبوك')">تبوك</div>
          <div class="city-option" onclick="selectCity('أبها')">أبها</div>
          <div class="city-option" onclick="selectCity('القصيم')">القصيم</div>
          <div class="city-option" onclick="selectCity('حائل')">حائل</div>
          <div class="city-option" onclick="selectCity('جازان')">جازان</div>
          <div class="city-option" onclick="selectCity('نجران')">نجران</div>
          <div class="city-option" onclick="selectCity('الباحة')">الباحة</div>
          <div class="city-option" onclick="selectCity('الجوف')">الجوف</div>
          <div class="city-option" onclick="selectCity('عرعر')">عرعر</div>
          <div class="city-option" onclick="selectCity('سكاكا')">سكاكا</div>
          <div class="city-option" onclick="selectCity('ينبع')">ينبع</div>
          <div class="city-option" onclick="selectCity('الطائف')">الطائف</div>
        </div>
      </div>
    </div>
    <div class="field-group">
      <label class="field-label">كلمة المرور</label>
      <input class="field-input" type="password" placeholder="أدخل كلمة المرور"/>
    </div>
    <div class="field-group">
      <label class="field-label">تأكيد كلمة المرور</label>
      <input class="field-input" type="password" placeholder="أعد كلمة المرور"/>
    </div>
    <button class="btn-main" onclick="go('verify')">إنشاء الحساب</button>
    <div class="auth-link">لديك حساب؟ <a onclick="go('login')">تسجيل الدخول</a></div>
  </div>
</div>

<!-- ===== VERIFY ===== -->
<div id="verify" class="screen">
  <div class="auth-card" style="margin:auto">
    <div class="auth-welcome" style="font-size:22px">تحقق من بريدك</div>
    <div class="auth-sub">أرسلنا كود مكون من 6 أرقام لبريدك الإلكتروني</div>
    <div class="code-boxes">
      <input class="code-box" maxlength="1" type="text"/>
      <input class="code-box" maxlength="1" type="text"/>
      <input class="code-box" maxlength="1" type="text"/>
      <input class="code-box" maxlength="1" type="text"/>
      <input class="code-box" maxlength="1" type="text"/>
      <input class="code-box" maxlength="1" type="text"/>
    </div>
    <button class="btn-main" onclick="go('home')">تأكيد</button>
    <div class="resend-link">لم تستلم الكود؟ <span>إعادة الإرسال</span></div>
  </div>
</div>

<!-- ===== HOME ===== -->
<div id="home" class="screen">

  <!-- هيدر المجلة -->
  <div class="home-header">
    <div>
      <div class="logo-text">المشهد السعودي</div>
      <div style="font-size:10px;color:var(--dim);letter-spacing:1px">التحليل السياسي السعودي</div>
    </div>
    <div style="display:flex;align-items:center;gap:10px">
      <div style="display:flex;align-items:center;gap:5px;font-size:10px;color:var(--dim)">
        <div class="live-dot"></div>مباشر
      </div>
      <div class="user-btn" onclick="go('profile')">س</div>
    </div>
  </div>

  <!-- شريط التاريخ والاقتباس -->
  <div style="padding:8px 16px;background:rgba(0,0,0,0.2);border-bottom:1px solid rgba(255,255,255,0.06);display:flex;align-items:center;justify-content:space-between;flex-shrink:0">
    <div style="font-size:10px;color:var(--dim)" id="homeDate"></div>
    <div style="font-size:10px;color:rgba(255,255,255,0.5);font-style:italic;text-align:left;max-width:60%">لسنا دعاة حرب ولكن إذا قرعت طبولها فنحن جاهزون</div>
  </div>

  <div class="scroll-body" style="padding:12px">

    <!-- الخبر الرئيسي -->
    <div onclick="go('events')" style="background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);border-radius:16px;padding:16px;margin-bottom:12px;cursor:pointer;position:relative;overflow:hidden">
      <div style="position:absolute;top:0;right:0;bottom:0;width:4px;background:var(--gold);border-radius:0 16px 16px 0"></div>
      <div style="display:flex;align-items:center;gap:6px;margin-bottom:8px">
        <div class="live-dot"></div>
        <span style="font-size:10px;color:var(--gold);font-weight:700;letter-spacing:1px">الحدث الأبرز</span>
        <span style="font-size:10px;color:var(--dim);margin-right:auto">منذ ساعتين</span>
      </div>
      <div style="font-family:'Amiri',serif;font-size:17px;font-weight:700;line-height:1.6;margin-bottom:8px">اجتماع مجلس الوزراء يناقش خطة التنويع الاقتصادي ضمن رؤية 2030</div>
      <div style="font-size:12px;color:rgba(255,255,255,0.6);line-height:1.7">تسريع مشاريع نيوم والبنية التحتية بتمويل يتجاوز 200 مليار ريال خلال العام الجاري</div>
      <div style="display:flex;align-items:center;gap:8px;margin-top:10px">
        <span style="font-size:10px;padding:2px 10px;border-radius:20px;background:rgba(240,192,64,0.12);color:var(--gold);border:1px solid rgba(240,192,64,0.25)">الداخل السعودي</span>
        <span style="font-size:10px;color:var(--dim)">عالي الأهمية ●</span>
      </div>
    </div>

    <!-- فاصل الأقسام -->
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px">
      <div style="height:1px;flex:1;background:rgba(255,255,255,0.1)"></div>
      <span style="font-size:10px;color:var(--dim);letter-spacing:2px">الأقسام</span>
      <div style="height:1px;flex:1;background:rgba(255,255,255,0.1)"></div>
    </div>

    <!-- شبكة الأقسام 2×2 -->
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:12px">

      <!-- التوقعات -->
      <div onclick="go('predictions')" style="background:rgba(100,200,255,0.06);border:1px solid rgba(100,200,255,0.15);border-radius:14px;padding:14px;cursor:pointer">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="rgba(100,200,255,0.9)" stroke-width="1.6" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2" fill="rgba(100,200,255,0.9)" stroke="none"/></svg>
          <span style="font-size:9px;padding:1px 7px;border-radius:10px;background:rgba(100,200,255,0.1);color:rgba(100,200,255,0.9)">12 توقع</span>
        </div>
        <div style="font-size:13px;font-weight:700">التوقعات</div>
        <div style="font-size:10px;color:var(--dim);margin-top:3px">أضف وتابع التوقعات</div>
      </div>

      <!-- المحللون -->
      <div onclick="go('analysts')" style="background:rgba(255,200,80,0.06);border:1px solid rgba(255,200,80,0.15);border-radius:14px;padding:14px;cursor:pointer">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="rgba(255,200,80,0.9)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="8 6 12 2 16 6"/><path d="M8 6h8v7a4 4 0 0 1-8 0V6z"/><line x1="9" y1="21" x2="15" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
          <span style="font-size:9px;padding:1px 7px;border-radius:10px;background:rgba(255,200,80,0.1);color:rgba(255,200,80,0.9)">الترتيب</span>
        </div>
        <div style="font-size:13px;font-weight:700">المحللون</div>
        <div style="font-size:10px;color:var(--dim);margin-top:3px">أفضل المحللين</div>
      </div>

      <!-- المنشورات -->
      <div onclick="go('posts')" style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.12);border-radius:14px;padding:14px;cursor:pointer">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.8)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
          <span style="font-size:9px;padding:1px 7px;border-radius:10px;background:rgba(255,255,255,0.08);color:rgba(255,255,255,0.7)">جديد</span>
        </div>
        <div style="font-size:13px;font-weight:700">المنشورات</div>
        <div style="font-size:10px;color:var(--dim);margin-top:3px">آراء وتحليلات</div>
      </div>

      <!-- الذكاء الاصطناعي -->
      <div onclick="go('ai')" style="background:rgba(255,160,50,0.06);border:1px solid rgba(255,160,50,0.15);border-radius:14px;padding:14px;cursor:pointer">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="rgba(255,160,50,0.9)" stroke-width="1.6" stroke-linecap="round"><rect x="7" y="7" width="10" height="10" rx="2"/><line x1="9" y1="4" x2="9" y2="7"/><line x1="15" y1="4" x2="15" y2="7"/><line x1="9" y1="17" x2="9" y2="20"/><line x1="15" y1="17" x2="15" y2="20"/><line x1="4" y1="9" x2="7" y2="9"/><line x1="4" y1="15" x2="7" y2="15"/><line x1="17" y1="9" x2="20" y2="9"/><line x1="17" y1="15" x2="20" y2="15"/></svg>
          <span style="font-size:9px;padding:1px 7px;border-radius:10px;background:rgba(255,160,50,0.1);color:rgba(255,160,50,0.9)">AI</span>
        </div>
        <div style="font-size:13px;font-weight:700">المحلل الذكي</div>
        <div style="font-size:10px;color:var(--dim);margin-top:3px">اسأل وحلل</div>
      </div>
    </div>

    <!-- فاصل -->
    <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px">
      <div style="height:1px;flex:1;background:rgba(255,255,255,0.1)"></div>
      <span style="font-size:10px;color:var(--dim);letter-spacing:2px">آخر التوقعات</span>
      <div style="height:1px;flex:1;background:rgba(255,255,255,0.1)"></div>
    </div>

    <!-- أحدث توقع -->
    <div onclick="go('predictions')" style="background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:14px;padding:13px;margin-bottom:10px;cursor:pointer">
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:7px">
        <div style="width:28px;height:28px;border-radius:50%;background:#3a6b35;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:700">م</div>
        <div style="font-size:11px;color:var(--dim)">محمد العتيبي · الرياض</div>
        <span style="font-size:9px;padding:1px 8px;border-radius:10px;background:rgba(240,192,64,0.12);color:var(--gold);border:1px solid rgba(240,192,64,0.2);margin-right:auto">قيد الانتظار</span>
      </div>
      <div style="font-size:13px;font-weight:600;margin-bottom:7px">التطبيع السعودي الإسرائيلي خلال 18 شهراً</div>
      <div style="display:flex;align-items:center;gap:8px">
        <div style="flex:1;height:4px;background:rgba(255,255,255,0.1);border-radius:2px;overflow:hidden">
          <div style="width:72%;height:100%;background:linear-gradient(90deg,var(--g3),var(--gold));border-radius:2px"></div>
        </div>
        <span style="font-size:12px;font-weight:700;color:var(--gold)">72%</span>
      </div>
    </div>

    <!-- شريط الأدوات السفلي -->
    <div style="display:flex;gap:8px;margin-bottom:4px">
      <div onclick="go('messages')" style="flex:1;background:rgba(100,220,220,0.06);border:1px solid rgba(100,220,220,0.15);border-radius:12px;padding:11px;display:flex;align-items:center;gap:8px;cursor:pointer">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(100,220,220,0.9)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        <span style="font-size:12px">المحادثات</span>
        <span style="margin-right:auto;width:16px;height:16px;border-radius:50%;background:var(--red);display:flex;align-items:center;justify-content:center;font-size:8px;font-weight:700">2</span>
      </div>
